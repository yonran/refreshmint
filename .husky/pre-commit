#!/usr/bin/env sh

# Exit on error
set -e

echo "Running pre-commit checks..."

# Run TypeScript type checking
echo "  → Type checking..."
npm run typecheck

# Run ESLint + Prettier (less-strict rules, all files)
echo "  → Linting & formatting..."
npm run lint

# Run ESLint with stricter type-checked rules on changed lines only
echo "  → Strict lint on diff..."
npm run lint-diff

echo "  → Cargo check..."
cd src-tauri
RUSTFLAGS="-D warnings" cargo check

echo "  → Cargo fmt (check)..."
cargo fmt --check

echo "  → Cargo clippy..."
cargo clippy --all-targets --all-features -- -D warnings

echo "  → Cargo test..."
cargo test

echo "✓ All pre-commit checks passed"
